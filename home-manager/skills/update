#!/usr/bin/env bash
# Refresh the revisions for Git sources in source.nix and source.local.nix.
# This is independent of Nix and only uses system git, awk, and perl.
# Public sources use HTTPS; ByteDance sources use the system SSH configuration.
set -euo pipefail

dir="${SKILLS_DIR:-$HOME/.config/home-manager/skills}"
export GIT_SSH_COMMAND=/usr/bin/ssh

refresh() {
  local file="$1" seen="" url ref oldrev new
  [ -f "$file" ] || return 0
  echo "==> $(basename "$file")"
  while IFS="$(printf '\t')" read -r url ref oldrev; do
    case " $seen " in *" $url "*) continue ;; esac   # Entries sharing a URL also share its revision.
    seen="$seen $url"
    new=$(git ls-remote "$url" "$ref" 2>/dev/null | head -1 | cut -f1 || true)
    if [ -z "$new" ]; then
      echo "  ${url##*/}: ls-remote failed (VPN or permission issue?); keeping ${oldrev:0:12}" >&2
    elif [ "$new" = "$oldrev" ]; then
      echo "  ${url##*/}: already up to date ${oldrev:0:12}"
    else
      perl -pi -e "s/\Q$oldrev\E/$new/g" "$file"     # Update every entry sharing this revision.
      echo "  ${url##*/}: ${oldrev:0:12} → ${new:0:12}"
    fi
  done < <(awk '
    /url[[:space:]]*=[[:space:]]*"/ { u=$0; sub(/^.*url[[:space:]]*=[[:space:]]*"/,"",u); sub(/".*/,"",u) }
    /ref[[:space:]]*=[[:space:]]*"/ { r=$0; sub(/^.*ref[[:space:]]*=[[:space:]]*"/,"",r); sub(/".*/,"",r) }
    /rev[[:space:]]*=[[:space:]]*"/ { v=$0; sub(/^.*rev[[:space:]]*=[[:space:]]*"/,"",v); sub(/".*/,"",v);
                                      if (u!="" && r!="" && v!="") { print u"\t"r"\t"v; u=""; r=""; v="" } }
  ' "$file")
}

refresh "$dir/source.nix"
refresh "$dir/source.local.nix"
echo "==> Skill source revisions refreshed."
