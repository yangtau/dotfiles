# Font configuration
font-size = 16
font-family = Monaco

theme = Claude
macos-titlebar-style = tabs
# background-opacity = 0.9
# background-blur = macos-glass-clear
# unfocused-split-opacity = 0.85
# unfocused-split-fill = #bbb
#
# macos-option-as-alt = left


copy-on-select = clipboard
# shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo,path

# keybinds
keybind = super+z=toggle_split_zoom
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+l=goto_split:right
keybind = super+shift+enter=toggle_quick_terminal

# mouse-scroll-multiplier = 0.5
