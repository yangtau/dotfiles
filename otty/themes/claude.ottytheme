[meta]
name = "Claude"
mode = "light"
description = "Imported from Ghostty on 2026-06-21"

[terminal]
foreground = "#3D3929"
background = "#FAF6F1"
cursor = "#D97706"
cursor-text = "#FAF6F1"
selection-foreground = "#3D3929"
selection-background = "#E8DFD3"
palette = [
    "#3D3929", "#C44A3F", "#5A8C5E", "#D97706", 
    "#4A7FB5", "#9B6B9E", "#4A9B8E", "#E8DFD3", 
    "#6B6456", "#E05A4F", "#6FA873", "#E89B3E", 
    "#5A9AD5", "#B580B8", "#5AB8A8", "#FAF6F1", 
]


[token]
foreground = "#18181B"
secondary  = "#52525B"
tertiary   = "#A1A1AA"
accent    = "#000000"
radius    = 8
font-ui   = ["-apple-system", "BlinkMacSystemFont", "SF Pro", "sans-serif"]
font-mono = ["JetBrains Mono", "Menlo", "monospace"]
font-size = 13

# The window itself becomes a translucent frosted panel. The sidebar,
# titlebar area, and the margin strip around the card all share this
# one backdrop (no per-section material needed).

[panel]
background = "#FFFFFF"
surface    = "#FAFAFA"
border     = "#E5E5E5"

[window]
material = "glass"

# Transparent sidebar — lets [window].material show through. Row text
# and hovers still use the regular theme tokens.
# border-right = "none" hides the 1px NSSplitView hairline divider
# between sidebar and the card so the card appears to float freely
# over the frosted window.

[sidebar]
border-right = "none"
background = "#ffffff00"
material = "glass"
padding-right = 0.0

[titlebar]
foreground = "#52525B"

[tab]
radius      = 6
foreground  = "#52525B"
font-weight = 400

[tab.active]
background  = "rgba(255,255,255,0.9)"
foreground  = "#18181B"
shadow      = "0 1px 2px rgba(0,0,0,0.05)"
font-weight = 700
border = "1px solid #e5e5e5"

[tab.hover]
background = "rgba(0,0,0,0.04)"

# The terminal viewport becomes a floating rounded card.
#   - margin insets it from the window edges. The renderer reserves the
#     titlebar height intrinsically so `top = 0` already lands flush with
#     the titlebar bottom; left/right/bottom leave the sidebar and window
#     edge visible so vibrancy wraps around the card.
#   - padding shrinks the default 8pt grid gutter so the card hugs
#     the text more tightly (the outer margin already provides
#     breathing room)
#   - radius + shadow + border ≈ Tailwind `rounded-lg border
#     border-neutral-200 shadow-md`

[container]
background = "#FFFFFF"
radius     = 15
shadow     = "0 1.5px 6px rgba(0,0,0,0.18)"
margin = [4, 16, 16, 16]
padding = [8, 16, 8, 16]
border = "1px solid #e5e5e5"

# Layout overrides — no sidebar in tabs-top / tabs-bottom layouts, so the
# card needs symmetric breathing room on every side instead of the
# asymmetric "0 left because sidebar already pads it" inset used above.
[container.tabs-top]
margin = 12

[container.tabs-bottom]
margin = 12
